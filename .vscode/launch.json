{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Start Downloader App",
            "skipFiles": ["<node_internals>/**"],
            "program": "${workspaceFolder}/server.js",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Server running at (http://localhost:5500)",
                "uriFormat": "%s"
            }
        }
    ]
}